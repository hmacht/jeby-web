# jeby-web environment variables

# Base URL of the jeby-go backend API (no trailing slash).
# In production set this to the deployed backend, e.g. https://jeby-api.onrender.com
JEBY_API_URL=http://localhost:8080

# API key sent as the `X-API-Key` header (must match the backend's API_KEY).
JEBY_API_KEY=

# Recommended on Render (behind a proxy) so SvelteKit builds correct absolute
# URLs for og:image / og:url. Set to your public site URL.
# ORIGIN=https://your-app.onrender.com
